APP_MODE=rule
# 可选: rule / llm
# rule: 完全规则模式
# llm : 启用大模型模式（若未配置 key，会自动回退 rule）

MODEL_PROVIDER=glm
# 可选: glm / deepseek

GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4.7

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-reasoner

LLM_TIMEOUT=120
LLM_TEMPERATURE=0.1